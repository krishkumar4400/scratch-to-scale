<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Welcome to products page</h1>
    <h2>
        <%= title %>
    </h2>

    <ul>
        <% products.forEach((product) => { %> 
            <li>
                <%= product.id %>
                <%= product.name %>
                <%= product.price %>
            </li>
            <% }); %>
    </ul>
</body>
</html>